generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["relationJoins"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  notionAccessToken  String
  notionWorkspaceId  String   @unique
  notionRefreshToken String
  tokenExpiresAt     DateTime
  createdAt          DateTime @default(now())
  tasks              Task[]
}

model Task {
  id           Int        @id @default(autoincrement())
  output       Json
  notionPageId String?
  topic        String
  status       TaskStatus
  userId       String
  errorMessage String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  user         User       @relation(fields: [userId], references: [id])
}

model OAuthState {
  id           String   @id @default(cuid())
  state        String   @unique
  codeVerifier String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
